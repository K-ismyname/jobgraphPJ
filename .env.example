# ============================================================
# LLM — 필수 (없으면 키워드 룰 기반 mock 추출로 동작)
# ============================================================
OPENAI_API_KEY=             # platform.openai.com 발급

# ============================================================
# 데이터 소스 — 없으면 jobs.json 캐시 사용, 그것도 없으면 mock 2개 반환
# ============================================================
ADZUNA_APP_ID=              # developer.adzuna.com 발급 (무료)
ADZUNA_APP_KEY=

# ============================================================
# 그래프 DB — 필수 (없으면 EnvironmentError로 기동 실패)
# ============================================================
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io   # Neo4j Aura 무료 티어
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ============================================================
# 평가 — 선택 (없으면 트레이싱·지표만 비활성화, 나머지 정상 동작)
# ============================================================
LANGFUSE_PUBLIC_KEY=        # cloud.langfuse.com 발급
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# GitHub — 선택 (없으면 confidence 레벨 상승 기능만 비활성화)
# ============================================================
GITHUB_TOKEN=               # repo read 권한 Personal Access Token

# ============================================================
# 파인튜닝 모델 — 예정/미구현 (6단계). 현재 코드는 USE_LOCAL_MODEL을 읽지 않고 항상 OpenAI 사용
# ============================================================
# HF Hub ID:     USE_LOCAL_MODEL=your_username/qwen2.5-1.5b-job-skill-extractor
# 로컬 경로:     USE_LOCAL_MODEL=./finetune/checkpoints/best_adapter
# 미설정 시:     OpenAI gpt-4o-mini 사용 (기본 동작)
USE_LOCAL_MODEL=

# HF Hub 업로드용 (03_evaluate.ipynb에서 사용)
HF_TOKEN=
HF_REPO_ID=                 # e.g. your_username/qwen2.5-1.5b-job-skill-extractor
